OPENAI_API_KEY=
OPENAI_SAFETY_IDENTIFIER=clinical_computer_use

# Dedicated agent profile login
MYLE_USERNAME=
MYLE_PASSWORD=

# Browser isolation
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PROFILE_DIR=C:\Users\joshu\Workspace\clinical_computer_use\.chrome_profile
DEBUG_URL=http://127.0.0.1:9333

# Optional EMR/domain restrictions
EMR_BASE_URL=https://chmg.medfarsolutions.com/html5
EMR_URL_PATTERN=chmg.medfarsolutions.com/html5
MYLE_LOGIN_USERNAME_SELECTOR=input[data-cy='login-username']
MYLE_LOGIN_PASSWORD_SELECTOR=input[data-cy='login-password']
MYLE_LOGIN_BUTTON_SELECTOR=button[data-cy='login-button']
ALLOWED_DOMAINS=chmg.medfarsolutions.com

# Default model/tooling
OPENAI_MODEL=gpt-5.4

# Runtime defaults
MAX_AGENT_STEPS=75
MAX_RUN_MINUTES=20
